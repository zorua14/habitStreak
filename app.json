        "backgroundColor": "#ffffff"
      },
      "package": "com.delewhoop.habit",
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "4f849658-b94d-47d2-985e-8cd1342119b2"
      }
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/splash-icon-light.png",
          "imageWidth": 200
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4f849658-b94d-47d2-985e-8cd1342119b2"
    }
  }
