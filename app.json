    "userInterfaceStyle": "automatic",
    "ios": {
      "userInterfaceStyle": "automatic",
      "supportsTablet": true,
      "bundleIdentifier": "com.delewhoop.habit",
    },
    "android": {
      "userInterfaceStyle": "automatic",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
